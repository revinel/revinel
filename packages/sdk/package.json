{
  "name": "@openads/sdk",
  "version": "0.1.0",
  "private": false,
  "description": "Universal headless OpenAds SDK for fetching and tracking publisher ads.",
  "keywords": [
    "ad-server",
    "ads",
    "advertising",
    "headless",
    "openads",
    "publisher",
    "sdk"
  ],
  "homepage": "https://github.com/piotrkulpinski/openads-js/tree/main/packages/sdk#readme",
  "license": "MIT",
  "author": "Piotr Kulpinski",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piotrkulpinski/openads-js.git",
    "directory": "packages/sdk"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "build": "tsdown && bun run prepare-package",
    "check-types": "tsc --noEmit --project tsconfig.json",
    "prepare-package": "bun ../../scripts/prepare-package.ts",
    "pub:release": "bun run build && npm publish ./dist --access public",
    "pub:beta": "bun run build && npm publish ./dist --access public --tag beta --no-git-checks",
    "pub:next": "bun run build && npm publish ./dist --access public --tag next --no-git-checks"
  },
  "dependencies": {},
  "devDependencies": {
    "@openads/tsconfig": "*",
    "typescript": "^6.0.3"
  }
}
