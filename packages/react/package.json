{
  "name": "@openads/react",
  "version": "0.1.0",
  "private": false,
  "description": "Headless React hooks and tracking helpers for OpenAds publisher integrations.",
  "keywords": [
    "ads",
    "advertising",
    "hooks",
    "openads",
    "publisher",
    "react"
  ],
  "homepage": "https://github.com/piotrkulpinski/openads-js/tree/main/packages/react#readme",
  "license": "MIT",
  "author": "Piotr Kulpinski",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/piotrkulpinski/openads-js.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.tsx",
  "module": "./src/index.tsx",
  "types": "./src/index.tsx",
  "exports": {
    ".": "./src/index.tsx"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "scripts": {
    "build": "tsdown && bun run prepare-package",
    "check-types": "tsc --noEmit --project tsconfig.json",
    "prepare-package": "bun ../../scripts/prepare-package.ts",
    "pub:release": "bun run build && npm publish ./dist --access public",
    "pub:beta": "bun run build && npm publish ./dist --access public --tag beta --no-git-checks",
    "pub:next": "bun run build && npm publish ./dist --access public --tag next --no-git-checks"
  },
  "dependencies": {
    "@openads/embeds": "workspace:*",
    "@openads/sdk": "workspace:*"
  },
  "devDependencies": {
    "@openads/tsconfig": "*",
    "@types/react": "^19.2.17",
    "react": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "react": ">=18 <20"
  }
}
